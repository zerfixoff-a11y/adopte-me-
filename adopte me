function openLevels(gid){
  cGame=gid;document.getElementById("crumb-game").textContent=GAMES[gid].label;
  const wrap=document.getElementById("levels-wrap");wrap.innerHTML="";
  LO[gid].forEach((lid,i)=>{
    const lv=GAMES[gid].levels[lid],st=lStatus(gid,lid);
    const card=document.createElement("div");card.className="level-card"+(st==="locked"?" locked":"");card.dataset.s=st;
    const tc=st==="open"?"t-open":st==="done"?"t-done":"t-locked";
    const tt=st==="open"?"Ouvert":st==="done"?"Terminé":"Verrouillé";
    const entry=progress[pk(gid,lid)];
    const meta=entry?"Dernier score : "+entry.score+"/"+entry.total:(st==="locked"?"Valide le niveau précédent (100%).":"Prêt à jouer.");
    card.innerHTML='<div class="lnum">0'+(i+1)+'</div><div class="linfo"><div class="ltitle">'+lv.label+'</div><div class="lmeta">'+meta+'</div></div><div class="ltag '+tc+'">'+tt+'</div>';
    card.addEventListener("click",()=>{if(st!=="locked")startQuiz(gid,lid);});
    wrap.appendChild(card);
  });
  show("screen-levels");
}
document.getElementById("btn-back-games").addEventListener("click",goHub);

/* QUIZ */
function startQuiz(gid,lid){
  cGame=gid;cLevel=lid;cQ=shuffleQ(GAMES[gid].levels[lid].questions);
  cIdx=0;cScore=0;aLog=[];show("screen-quiz");renderQ();
}
function renderQ(){
  aLocked=false;
  const total=cQ.length,item=cQ[cIdx];
  const ld=GAMES[cGame].levels[cLevel];
  document.getElementById("q-prog").textContent=GAMES[cGame].label+" — "+ld.label+" — Q"+(cIdx+1)+" / "+total;
  document.getElementById("q-fill").style.width=(cIdx/total)*100+"%";
  const c=document.getElementById("q-content");
  if(cGame==="trivia") c.innerHTML='<p class="qtext">'+item.q+'</p>';
  else c.innerHTML='<p class="qquote">'+item.clue+'</p><p class="qwho">Qui a dit ça ?</p>';
  const ow=document.getElementById("q-opts");ow.innerHTML="";
  item.options.forEach((opt,i)=>{
    const b=document.createElement("button");b.className="opt";b.textContent=opt;
    b.addEventListener("click",()=>selectA(i,b));ow.appendChild(b);
  });
}
function selectA(i,btn){
  if(aLocked)return;aLocked=true;
  const item=cQ[cIdx];
  const btns=document.querySelectorAll("#q-opts .opt");btns.forEach(b=>b.disabled=true);
  const ok=(i===item.correct);
  if(ok){btn.classList.add("correct");cScore++;}
  else{btn.classList.add("wrong");btns[item.correct].classList.add("correct");}
  aLog.push({question:cGame==="trivia"?item.q:item.clue,chosen:item.options[i],correctAnswer:item.options[item.correct],isCorrect:ok});
  setTimeout(()=>{cIdx++;if(cIdx<cQ.length)renderQ();else finishQ();},900);
}
async function finishQ(){
  const total=cQ.length;
  /* 100% requis pour valider et débloquer le niveau suivant */
  const passed=(cScore===total);
  const ld=GAMES[cGame].levels[cLevel];
  const lastG=GO[GO.length-1];
  const lastL=LO[lastG][LO[lastG].length-1];
  const isFinal=(cGame===lastG&&cLevel===lastL);

  progress[pk(cGame,cLevel)]={done:passed,score:cScore,total,log:aLog,gameLabel:GAMES[cGame].label,levelLabel:ld.label};
  saveAll();show("screen-result");

  document.getElementById("r-level").textContent=GAMES[cGame].label+" — "+ld.label;
  document.getElementById("r-score").textContent=cScore+" / "+total;
  document.getElementById("r-status").textContent=passed?"✅ Niveau validé — suite débloquée !":"❌ Il faut tout juste. Rejoue pour avancer.";
  document.getElementById("r-status").style.color=passed?"var(--green)":"var(--red)";

  const blb=document.getElementById("btn-back-levels");
  if(isFinal){blb.textContent="← Retour à l'accueil";blb.onclick=()=>goHub();}
  else{blb.textContent="Retour aux niveaux";blb.onclick=()=>openLevels(cGame);}

  const recap=document.getElementById("recap");recap.innerHTML="";
  aLog.forEach((r,idx)=>{
    const row=document.createElement("div");row.className="recap-item";
    row.innerHTML='<span class="ri-icon '+(r.isCorrect?"ok":"ko")+'">'+(r.isCorrect?"✔":"✘")+'</span><div><div class="ri-q">'+(idx+1)+'. '+r.question+'</div><div class="ri-a">Réponse : <strong>'+r.chosen+'</strong>'+(r.isCorrect?"":" — Bonne : <strong>"+r.correctAnswer+"</strong>")+'</div></div>';
    recap.appendChild(row);
  });

  const st=document.getElementById("r-send");st.textContent="Envoi…";
  const ch=gc(player.charId);
  const lines=["🏀 **"+GAMES[cGame].label+" / "+ld.label+"**","Joueur : "+player.prenom+" "+player.nom+" ("+player.age+" ans) | "+ch.av+" "+ch.name,"Score : "+cScore+" / "+total+" — "+(passed?"✅":"❌"),""];
  aLog.forEach((r,idx)=>{lines.push((r.isCorrect?"✅":"❌")+" Q"+(idx+1)+" : "+r.question+" → "+(r.isCorrect?r.chosen:"Donnée : "+r.chosen+" | Bonne : "+r.correctAnswer));});
  const ok=await notifyLong(lines);
  st.textContent=ok?"Résultat envoyé.":"Résultat non envoyé.";
}

/* ZONE */
document.getElementById("btn-send-aomine").addEventListener("click",async()=>{
  const btn=document.getElementById("btn-send-aomine");
  btn.disabled=true;btn.textContent="Envoi en cours…";
  const ch=gc(player.charId);
  const lines=["🔥 **Rapport complet — "+player.prenom+" "+player.nom+" ("+player.age+" ans)**","Personnage : "+ch.av+" "+ch.name,""];
  GO.forEach(gid=>{LO[gid].forEach(lid=>{
    const e=progress[pk(gid,lid)];if(!e)return;
    lines.push("__"+e.gameLabel+" — "+e.levelLabel+"__ — "+e.score+"/"+e.total+(e.done?" ✅":" ❌"));
    (e.log||[]).forEach((r,idx)=>{lines.push((r.isCorrect?"✅":"❌")+" Q"+(idx+1)+" : "+r.question+" → "+(r.isCorrect?r.chosen:"Donnée : "+r.chosen+" | Bonne : "+r.correctAnswer));});
    lines.push("");
  });});
  lines.push("🔑 **Code d'accès : `"+CONFIG.FINAL_CODE+"`**");
  lines.push("_(Transmets ce code au joueur si tu l'acceptes)_");
  const ok=await notifyLong(lines);
  btn.disabled=false;btn.textContent="Envoyer mes réponses à Aomine";
  const errEl=document.getElementById("zone-err");
  if(!ok){errEl.textContent="L'envoi a échoué. Réessaie.";return;}
  errEl.textContent="";show("screen-wait");
});
document.getElementById("btn-unlock").addEventListener("click",()=>{
  const code=document.getElementById("access-code").value.trim();
  const err=document.getElementById("wait-err");
  if(!code){err.textContent="Entre le code transmis par Aomine Daiki.";return;}
  if(code.toUpperCase()!==CONFIG.FINAL_CODE.toUpperCase()){err.textContent="Code incorrect.";return;}
  err.textContent="";show("screen-fintro");
});

/* FINAL */
let fi=0,fsc=0,flog=[],ftimer=null,ftime=0,flocked=false,fq=[];
document.getElementById("btn-start-final").addEventListener("click",()=>{
  fi=0;fsc=0;flog=[];fq=shuffleQ(FQ);show("screen-fquiz");renderFQ();
});
document.getElementById("btn-fr-home").addEventListener("click",goHub);
function renderFQ(){
  flocked=false;
  const total=fq.length,item=fq[fi];
  document.getElementById("fq-prog").textContent="Question "+(fi+1)+" / "+total;
  document.getElementById("fq-fill").style.width=(fi/total)*100+"%";
  document.getElementById("fq-text").textContent=item.q;
  const w=document.getElementById("fq-opts");w.innerHTML="";
  item.options.forEach((opt,i)=>{
    const b=document.createElement("button");b.className="opt";b.textContent=opt;
    b.addEventListener("click",()=>selectFQ(i,b));w.appendChild(b);
  });
  startFT();
}
function startFT(){
  clearInterval(ftimer);ftime=FT;
  const el=document.getElementById("fq-timer");el.textContent=ftime;el.classList.remove("urgent");
  ftimer=setInterval(()=>{
    ftime--;el.textContent=ftime;
    if(ftime<=5)el.classList.add("urgent");
    if(ftime<=0){clearInterval(ftimer);if(!flocked)timeoutFQ();}
  },1000);
}
function timeoutFQ(){
  flocked=true;const item=fq[fi];
  const btns=document.querySelectorAll("#fq-opts .opt");btns.forEach(b=>b.disabled=true);
  btns[item.correct].classList.add("correct");
  flog.push({question:item.q,chosen:"(temps écoulé)",correctAnswer:item.options[item.correct],isCorrect:false});
  setTimeout(advFQ,1100);
}
function selectFQ(i,btn){
  if(flocked)return;flocked=true;clearInterval(ftimer);
  const item=fq[fi];
  const btns=document.querySelectorAll("#fq-opts .opt");btns.forEach(b=>b.disabled=true);
  const ok=(i===item.correct);
  if(ok){btn.classList.add("correct");fsc++;}
  else{btn.classList.add("wrong");btns[item.correct].classList.add("correct");}
  flog.push({question:item.q,chosen:item.options[i],correctAnswer:item.options[item.correct],isCorrect:ok});
  setTimeout(advFQ,900);
}
function advFQ(){fi++;if(fi<fq.length)renderFQ();else finishF();}
async function finishF(){
  clearInterval(ftimer);const total=fq.length,passed=(fsc===total);
  show("screen-fres");
  const t=document.getElementById("fr-title"),tx=document.getElementById("fr-text");
  if(passed){t.textContent="Félicitations. Tu as ta place parmi nous.";t.className="fr-title pass";tx.textContent="10 / 10. Aomine Daiki n'a rien à redire.";}
  else{t.textContent="Seuls les génies peuvent avoir leur place.";t.className="fr-title fail";tx.textContent="Score final : "+fsc+" / "+total+".";}
  const st=document.getElementById("fr-send");st.textContent="Envoi…";
  const ch=gc(player.charId);
  const lines=["⚡ **Défi final — "+player.prenom+" "+player.nom+"**","Personnage : "+ch.av+" "+ch.name,"Score : "+fsc+" / "+total+" — "+(passed?"✅ ACCEPTÉ":"❌ REFUSÉ"),""];
  flog.forEach((r,idx)=>{lines.push((r.isCorrect?"✅":"❌")+" Q"+(idx+1)+" : "+r.question+" → "+(r.isCorrect?r.chosen:"Donnée : "+r.chosen+" | Bonne : "+r.correctAnswer));});
  const ok=await notifyLong(lines);
  st.textContent=ok?"Résultat final envoyé.":"Résultat non envoyé.";
}

/* START */
loadAll();
if(player.nom&&player.prenom&&player.charId)showWB();
else{initCarousel();show("screen-char");}
</script>
