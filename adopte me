async function notifyLong(lines){
  let chunk="",chunks=[];
  for(const l of lines){if((chunk+"\n"+l).length>1800){chunks.push(chunk);chunk="";}chunk+=(chunk?"\n":"")+l;}
  if(chunk)chunks.push(chunk);
  let ok=false;for(const c of chunks){const r=await sendDiscord(c);ok=ok||r;}return ok;
}

