<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quiz Génération des Miracles — Style Adopt Me</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;600;700;800&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
:root{
  /* Palette façon Adopt Me : pastel, rond, bonbon */
  --bg1:#bfe9ff;        /* ciel pastel */
  --bg2:#ffd9ef;        /* rose pastel */
  --card:#ffffff;
  --card-line:#2b2240;  /* contour "sticker" foncé */
  --ink:#3a2f55;        /* texte principal violet foncé */
  --ink-soft:#8479a3;   /* texte secondaire */
  --pink:#ff6fa5;       /* accent principal */
  --pink-d:#e0488a;
  --pink-bg:#ffe3ef;
  --purple:#7b5ee8;     /* accent violet (zone VIP) */
  --purple-d:#5a3fc0;
  --purple-bg:#ece7ff;
  --blue:#46c6ff;       /* accent bleu */
  --blue-bg:#e2f6ff;
  --yellow:#ffc93c;     /* bucks / étoiles */
  --green:#3ecf73;      /* succès */
  --green-bg:#e3fbeb;
  --red:#ff5c6c;        /* verrouillé / erreur */
  --red-bg:#ffe6e8;
  --grey-bg:#eef0fb;
  --grey-line:#d8d9ee;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{
  min-height:100vh;font-family:'Nunito',sans-serif;
  background:linear-gradient(160deg,var(--bg1) 0%,var(--bg2) 100%);
  background-attachment:fixed;
  color:var(--ink);
  display:flex;align-items:flex-start;justify-content:center;
  padding:48px 16px 100px;
}
.wrap{width:100%;max-width:640px;}

.eyebrow{
  display:inline-flex;align-items:center;gap:6px;
  font-size:12px;font-weight:800;letter-spacing:.04em;text-transform:uppercase;
  color:var(--purple-d);background:var(--purple-bg);
  padding:6px 14px;border-radius:20px;margin-bottom:14px;
  border:2px solid var(--purple);
}
h1.brand{
  font-family:'Baloo 2',sans-serif;font-weight:800;
  font-size:clamp(38px,8vw,58px);line-height:1.02;
  color:var(--ink);margin-bottom:10px;
  text-shadow:3px 3px 0 #fff, -1px -1px 0 rgba(255,255,255,.4);
}
h1.brand em{font-style:normal;color:var(--pink);}
.sub{font-size:14.5px;color:var(--ink-soft);margin-bottom:36px;line-height:1.65;font-weight:700;}

.panel{
  background:var(--card);border:3px solid var(--card-line);
  border-radius:28px;padding:30px clamp(20px,5.5vw,40px);
  margin-bottom:18px;position:relative;
  box-shadow:0 8px 0 rgba(58,47,85,.12),0 16px 30px rgba(58,47,85,.10);
}
.panel.red{border-color:var(--purple);}
.ptitle{
  display:inline-flex;align-items:center;gap:8px;
  font-size:13px;letter-spacing:.02em;text-transform:uppercase;
  color:#fff;margin-bottom:20px;font-weight:800;
  background:var(--pink);padding:6px 14px;border-radius:16px;
}
.panel.red .ptitle{background:var(--purple);}

label{
  display:block;font-size:12px;letter-spacing:.03em;text-transform:uppercase;
  color:var(--ink-soft);margin:18px 0 6px;font-weight:800;
}
label:first-of-type{margin-top:0;}
input[type=text],input[type=number]{
  width:100%;background:var(--grey-bg);border:2.5px solid var(--grey-line);
  border-radius:16px;padding:13px 16px;color:var(--ink);
  font-size:15px;font-family:'Nunito',sans-serif;font-weight:700;outline:none;
  transition:border-color .15s,background .15s;
}
input:focus{border-color:var(--pink);background:#fff;}
.error{color:var(--red);font-size:13px;margin-top:10px;min-height:16px;font-weight:700;}

.btn{
  appearance:none;border:none;cursor:pointer;
  font-family:'Baloo 2',sans-serif;font-size:15px;font-weight:700;
  letter-spacing:.01em;
  padding:13px 26px;border-radius:18px;
  transition:transform .1s,filter .15s;
  box-shadow:0 5px 0 rgba(0,0,0,.15);
}
.btn:active{transform:translateY(3px);box-shadow:0 2px 0 rgba(0,0,0,.15);}
.btn-p{background:var(--pink);color:#fff;}
.btn-p:hover{filter:brightness(1.06);}
.btn-d{background:var(--purple);color:#fff;}
.btn-d:hover{filter:brightness(1.08);}
.btn-g{background:#fff;border:2.5px solid var(--grey-line);color:var(--ink-soft);box-shadow:none;}
.btn-g:hover{border-color:var(--pink);color:var(--pink-d);}
.btn:disabled{background:var(--grey-bg);color:#b9bbd6;cursor:not-allowed;box-shadow:none;}
.btn-row{margin-top:26px;display:flex;gap:10px;flex-wrap:wrap;}

/* CAROUSEL */
.char-carousel{overflow:hidden;border-radius:22px;margin-bottom:16px;}
.char-track{display:flex;transition:transform .35s cubic-bezier(.4,0,.2,1);}
.char-slide{
  min-width:100%;display:flex;flex-direction:column;align-items:center;
  padding:30px 20px 24px;background:linear-gradient(160deg,var(--blue-bg),var(--pink-bg));
  border:2.5px solid var(--grey-line);border-radius:22px;gap:4px;
}
.ca{font-size:58px;line-height:1;margin-bottom:6px;filter:drop-shadow(0 4px 0 rgba(58,47,85,.12));}
.cn{font-family:'Baloo 2',sans-serif;font-weight:700;font-size:23px;color:var(--ink);}
.cr{font-size:12px;font-weight:800;color:var(--pink-d);text-align:center;}
.cage{font-size:12px;color:var(--ink-soft);font-weight:700;}
.cteam{font-size:11px;padding:3px 12px;border:2px solid var(--purple);border-radius:20px;color:var(--purple-d);font-weight:800;background:#fff;}
.char-nav{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-top:10px;}
.char-arrow{
  background:#fff;border:2.5px solid var(--grey-line);color:var(--ink-soft);
  width:40px;height:40px;border-radius:14px;font-size:20px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  transition:border-color .15s,color .15s;font-weight:800;
}
.char-arrow:hover{border-color:var(--pink);color:var(--pink-d);}
.char-dots{display:flex;gap:6px;flex-wrap:wrap;justify-content:center;flex:1;}
.char-dot{width:7px;height:7px;border-radius:50%;background:var(--grey-line);cursor:pointer;transition:background .15s,transform .15s;}
.char-dot.active{background:var(--pink);transform:scale(1.4);}
.char-select-btn{
  width:100%;margin-top:12px;padding:13px;border-radius:16px;
  border:2.5px solid var(--pink);cursor:pointer;
  font-family:'Baloo 2',sans-serif;font-weight:700;font-size:14px;
  background:var(--pink-bg);color:var(--pink-d);
  transition:background .15s,border-color .15s;
}
.char-select-btn:hover{background:#ffd3e7;}
.char-select-btn.sel{background:var(--pink);color:#fff;border-color:var(--pink-d);}

/* WELCOME BACK */
.wb-name{font-family:'Baloo 2',sans-serif;font-weight:800;font-size:30px;color:var(--ink);}
.wb-role{font-size:12px;color:var(--pink-d);text-transform:uppercase;font-weight:800;margin-bottom:4px;letter-spacing:.03em;}
.wb-info{font-size:13px;color:var(--ink-soft);margin-top:4px;font-weight:700;}
.wb-actions{display:flex;flex-direction:column;gap:10px;margin-top:22px;}
.wb-action{
  padding:15px 18px;border-radius:18px;border:2.5px solid var(--grey-line);background:var(--grey-bg);
  cursor:pointer;text-align:left;display:flex;align-items:center;gap:14px;
  transition:border-color .15s,background .15s,transform .1s;
}
.wb-action:hover{border-color:var(--blue);background:var(--blue-bg);transform:translateY(-1px);}
.wb-action-ico{font-size:24px;flex-shrink:0;}
.wb-action-title{font-weight:800;font-size:14px;color:var(--ink);font-family:'Baloo 2',sans-serif;}
.wb-action-desc{font-size:12px;color:var(--ink-soft);margin-top:3px;font-weight:700;}
.wb-action.danger{border-color:#ffd0d5;background:var(--red-bg);}
.wb-action.danger:hover{border-color:var(--red);}
.wb-action.danger .wb-action-title{color:var(--red);}

/* HUB */
.hub-head{display:flex;align-items:center;gap:14px;margin-bottom:26px;}
.hub-av{font-size:36px;background:var(--pink-bg);border:2.5px solid var(--pink);border-radius:16px;padding:6px 10px;}
.hub-ey{font-size:12px;letter-spacing:.03em;text-transform:uppercase;color:var(--ink-soft);font-weight:800;}
.hub-nm{font-family:'Baloo 2',sans-serif;font-weight:800;font-size:22px;color:var(--ink);}
.games{display:grid;gap:12px;}
.game-card{
  border:2.5px solid var(--grey-line);border-radius:22px;padding:22px 24px;
  cursor:pointer;background:var(--grey-bg);transition:border-color .15s,background .15s,transform .1s;
  position:relative;overflow:hidden;
}
.game-card:not(.locked):hover{border-color:var(--pink);background:var(--pink-bg);transform:translateY(-2px);}
.game-card.locked{opacity:.55;cursor:not-allowed;}
.gc-icon{font-size:30px;margin-bottom:8px;}
.gc-title{font-family:'Baloo 2',sans-serif;font-weight:700;font-size:19px;color:var(--ink);}
.gc-desc{font-size:12.5px;color:var(--ink-soft);margin-top:5px;line-height:1.55;font-weight:700;}
.gc-meta{margin-top:12px;}
.pill{
  display:inline-block;font-size:10px;text-transform:uppercase;font-weight:800;
  letter-spacing:.05em;padding:4px 11px;border-radius:20px;
  border:2px solid var(--grey-line);color:var(--ink-soft);background:#fff;
}
.pill.open{border-color:var(--blue);color:#1b8cc4;}
.pill.done{border-color:var(--green);color:#23a85a;}

/* LEVELS */
.crumb-btn{
  background:#fff;border:2.5px solid var(--grey-line);color:var(--ink-soft);
  font-family:'Baloo 2',sans-serif;font-size:13px;font-weight:700;
  padding:8px 16px;border-radius:14px;cursor:pointer;
  transition:border-color .15s,color .15s;margin-bottom:16px;
}
.crumb-btn:hover{border-color:var(--pink);color:var(--pink-d);}
.crumb-lbl{font-size:12px;letter-spacing:.03em;text-transform:uppercase;color:var(--ink-soft);margin-bottom:14px;font-weight:800;}
.crumb-lbl b{color:var(--pink-d);}
.levels{display:grid;gap:10px;}
.level-card{
  border:2.5px solid var(--grey-line);border-radius:20px;padding:16px 20px;
  display:flex;align-items:center;justify-content:space-between;gap:14px;
  cursor:pointer;background:var(--grey-bg);transition:border-color .15s,background .15s,transform .1s;
}
.level-card.locked{cursor:not-allowed;opacity:.5;}
.level-card:not(.locked):hover{border-color:var(--pink);background:var(--pink-bg);transform:translateY(-1px);}
.lnum{
  font-size:34px;line-height:1;width:46px;text-align:center;
}
.level-card[data-s="open"]   .lnum::before{content:"🥚";}
.level-card[data-s="done"]   .lnum::before{content:"🐣";}
.level-card[data-s="locked"] .lnum::before{content:"🔒";font-size:24px;}
.linfo{flex:1;}
.ltitle{font-size:15px;font-weight:800;color:var(--ink);font-family:'Baloo 2',sans-serif;}
.lmeta{font-size:12px;color:var(--ink-soft);margin-top:3px;font-weight:700;}
.ltag{
  font-size:10px;text-transform:uppercase;font-weight:800;
  letter-spacing:.04em;padding:4px 11px;border-radius:20px;border:2px solid currentColor;white-space:nowrap;
}
.t-open{color:#1b8cc4;}
.t-done{color:#23a85a;}
.t-locked{color:#a9abc9;}

/* QUIZ */
.qprog{font-size:12px;letter-spacing:.03em;text-transform:uppercase;color:var(--ink-soft);margin-bottom:10px;font-weight:800;}
.qbar{height:10px;background:var(--grey-bg);margin-bottom:26px;overflow:hidden;border-radius:20px;border:2px solid var(--grey-line);}
.qbar-fill{height:100%;background:linear-gradient(90deg,var(--pink),var(--yellow));transition:width .3s;border-radius:20px;}
.qtext{font-size:19px;line-height:1.4;font-weight:800;color:var(--ink);margin-bottom:22px;font-family:'Baloo 2',sans-serif;}
.qquote{
  font-family:'Baloo 2',sans-serif;font-weight:600;
  font-size:clamp(20px,4vw,27px);line-height:1.35;color:var(--ink);
  border-left:5px solid var(--pink);padding-left:16px;margin-bottom:8px;
}
.qwho{font-size:12px;text-transform:uppercase;letter-spacing:.03em;color:var(--ink-soft);margin-bottom:20px;font-weight:800;}
.options{display:grid;gap:10px;}
.opt{
  text-align:left;border:2.5px solid var(--grey-line);background:var(--grey-bg);
  color:var(--ink);padding:14px 18px;border-radius:16px;cursor:pointer;
  font-size:14.5px;font-family:'Nunito',sans-serif;font-weight:700;
  transition:border-color .1s,background .1s,transform .1s;
}
.opt:hover{border-color:var(--blue);background:var(--blue-bg);transform:translateY(-1px);}
.opt.correct{border-color:var(--green);background:var(--green-bg);color:#1d7a45;}
.opt.wrong{border-color:var(--red);background:var(--red-bg);color:#c23a47;}
.opt:disabled{cursor:default;}

/* RESULT */
.rlbl{font-size:12px;letter-spacing:.03em;text-transform:uppercase;color:var(--ink-soft);margin-bottom:6px;font-weight:800;}
.rscore{font-family:'Baloo 2',sans-serif;font-weight:800;font-size:54px;color:var(--pink);line-height:1;}
.rstatus{font-size:14.5px;margin-top:10px;font-weight:800;}
.ssend{font-size:12px;color:var(--ink-soft);margin-top:16px;font-weight:700;}
.recap{margin-top:22px;border-top:2.5px dashed var(--grey-line);padding-top:16px;}
.recap-item{display:flex;gap:10px;align-items:flex-start;padding:7px 0;font-size:13px;line-height:1.4;}
.ri-icon{flex-shrink:0;width:20px;}
.ri-icon.ok{color:var(--green);}
.ri-icon.ko{color:var(--red);}
.ri-q{color:var(--ink);font-weight:700;}
.ri-a{color:var(--ink-soft);margin-top:2px;font-weight:600;}

/* ZONE */
.zone-card{border:2.5px solid var(--purple);border-radius:22px;padding:22px;background:var(--purple-bg);}
.zone-title{font-family:'Baloo 2',sans-serif;font-weight:700;font-size:20px;color:var(--purple-d);}
.zone-desc{font-size:13.5px;color:var(--ink-soft);margin-top:8px;line-height:1.65;font-weight:700;}
.wi-icon{font-size:40px;margin-bottom:12px;}
.wi-title{font-family:'Baloo 2',sans-serif;font-weight:700;font-size:20px;color:var(--ink);}
.wi-text{color:var(--ink-soft);font-size:13.5px;margin-top:10px;line-height:1.65;font-weight:700;}
.pulse{display:inline-block;width:9px;height:9px;border-radius:50%;background:var(--purple);margin-right:8px;animation:pulse 1.2s infinite;}
@keyframes pulse{0%,100%{opacity:.25;}50%{opacity:1;}}

/* FINAL */
.tw{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.timer{font-family:'Baloo 2',sans-serif;font-weight:800;font-size:24px;color:var(--purple);min-width:48px;text-align:right;}
.timer.urgent{animation:pulse .5s infinite;color:var(--red);}
.fr-title{font-family:'Baloo 2',sans-serif;font-weight:800;font-size:clamp(24px,5vw,34px);line-height:1.2;margin-bottom:12px;}
.fr-title.pass{color:var(--green);}
.fr-title.fail{color:var(--red);}
.fr-text{font-size:14.5px;color:var(--ink-soft);line-height:1.6;font-weight:700;}

#zone-inline{margin-top:12px;}
.hidden{display:none !important;}
footer{text-align:center;color:var(--ink-soft);font-size:11px;margin-top:36px;font-weight:700;opacity:.7;}
</style>
</head>
<body>
<div class="wrap">
  <p class="eyebrow">🐾 Quiz Adoption · Édition spéciale</p>
  <h1 class="brand">Generation<br>of <em>Miracles</em></h1>
  <p class="sub">🥚 2 jeux, 3 œufs à faire éclore dans chacun. Et si tu vas jusqu'au bout — quelqu'un d'autre t'attend dans l'enclos VIP.</p>

  <!-- WELCOME BACK -->
  <section id="screen-wb" class="panel hidden">
    <div id="wb-av" style="font-size:46px;margin-bottom:14px;"></div>
    <p class="wb-role" id="wb-char"></p>
    <p class="wb-name" id="wb-name"></p>
    <p class="wb-info" id="wb-info"></p>
    <div class="wb-actions">
      <div class="wb-action" id="wb-continue">
        <span class="wb-action-ico">▶️</span>
        <div><div class="wb-action-title">Continuer</div><div class="wb-action-desc">Reprendre là où tu t'es arrêté</div></div>
      </div>
      <div class="wb-action" id="wb-new">
        <span class="wb-action-ico">➕</span>
        <div><div class="wb-action-title">Inscrire un autre joueur</div><div class="wb-action-desc">Créer un nouveau profil</div></div>
      </div>
      <div class="wb-action danger" id="wb-delete">
        <span class="wb-action-ico">🗑️</span>
        <div><div class="wb-action-title">Supprimer ce profil</div><div class="wb-action-desc">Effacer toute la progression</div></div>
      </div>
    </div>
  </section>

  <!-- CHAR SELECTION -->
  <section id="screen-char" class="panel hidden">
    <p class="ptitle">Étape 1 — Choisis ton personnage</p>
    <p style="font-size:13px;color:var(--t2);margin-bottom:22px;">Fais défiler les joueurs et sélectionne celui qui te représente.</p>
    <div class="char-carousel"><div class="char-track" id="char-track"></div></div>
    <div class="char-nav">
      <button class="char-arrow" id="char-prev">‹</button>
      <div class="char-dots" id="char-dots"></div>
      <button class="char-arrow" id="char-next">›</button>
    </div>
    <button class="char-select-btn" id="char-sel-btn">Choisir ce personnage</button>
    <p class="error" id="char-err"></p>
    <div class="btn-row">
      <button class="btn btn-p" id="btn-char-next" disabled>Continuer →</button>
    </div>
  </section>

  <!-- REGISTER -->
  <section id="screen-reg" class="panel hidden">
    <p class="ptitle">Étape 2 — Ton identité</p>
    <div id="reg-recap" style="display:flex;align-items:center;gap:12px;padding:14px 16px;background:var(--s2);border:1px solid rgba(200,164,74,.18);border-radius:1px;margin-bottom:24px;">
      <span id="reg-av" style="font-size:28px;"></span>
      <div>
        <div style="font-size:10px;text-transform:uppercase;letter-spacing:.16em;color:var(--t2);">Personnage choisi</div>
        <div id="reg-char" style="font-family:'Cormorant Garamond',serif;font-weight:700;font-size:17px;text-transform:uppercase;color:var(--gold);"></div>
      </div>
    </div>
    <label for="reg-nom">Nom</label>
    <input id="reg-nom" type="text" placeholder="ex : Tetsuya" autocomplete="off">
    <label for="reg-prenom">Prénom</label>
    <input id="reg-prenom" type="text" placeholder="ex : Kuroko" autocomplete="off">
    <label for="reg-age">Âge</label>
    <input id="reg-age" type="number" min="1" max="120" placeholder="16">
    <div class="btn-row">
      <button class="btn btn-p" id="btn-register">Entrer sur le terrain</button>
      <button class="btn btn-g" id="btn-reg-back">← Retour</button>
    </div>
    <p class="error" id="reg-err"></p>
  </section>

  <!-- HUB -->
  <section id="screen-games" class="panel hidden">
    <div class="hub-head">
      <span class="hub-av" id="hub-av"></span>
      <div>
        <p class="hub-ey">Bienvenue</p>
        <p class="hub-nm" id="hub-name"></p>
      </div>
    </div>
    <div class="games" id="games-wrap"></div>
  </section>

  <!-- ZONE AOMINE -->
  <section id="screen-zone" class="panel red hidden">
    <p class="ptitle">✨ Enclos VIP — Daiki Aomine</p>
    <div class="zone-card">
      <p class="zone-desc">🐾 Envoie ton dossier d'adoption à Aomine Daiki. S'il estime que tu en vaux la peine, il te laissera tenter sa dernière épreuve — 10 questions, zéro droit à l'erreur, pour adopter l'œuf légendaire.</p>
      <div class="btn-row">
        <button class="btn btn-d" id="btn-send-aomine">📨 Envoyer mon dossier à Aomine</button>
        <button class="btn btn-g" id="btn-zone-back">← Retour</button>
      </div>
      <p class="error" id="zone-err"></p>
    </div>
  </section>

  <!-- WAITING -->
  <section id="screen-wait" class="panel red hidden">
    <div class="wi-icon">🥚</div>
    <p class="wi-title"><span class="pulse"></span>En attente d'Aomine Daiki</p>
    <p class="wi-text">Ton dossier vient d'être envoyé. Si Aomine Daiki t'accepte dans l'enclos VIP, il t'enverra un code sur Discord. Entre-le ici dès que tu l'as.</p>
    <label for="access-code" style="margin-top:24px;">Code d'accès</label>
    <input id="access-code" type="text" placeholder="••••••••">
    <div class="btn-row">
      <button class="btn btn-d" id="btn-unlock">Valider le code</button>
    </div>
    <p class="error" id="wait-err"></p>
  </section>

  <!-- FINAL INTRO -->
  <section id="screen-fintro" class="panel red hidden">
