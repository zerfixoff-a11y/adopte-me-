    zb.innerHTML='<p style="color:var(--ink-soft);font-size:12px;margin-top:10px;font-weight:700;">🔒 Fais éclore tous les œufs des deux jeux (100%) pour débloquer l\'enclos VIP d\'Aomine Daiki.</p>';
  }
}
