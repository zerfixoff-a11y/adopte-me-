function allDone(gid){return LO[gid].every(l=>{const e=progress[pk(gid,l)];return e&&e.done;});}

/* CORRECTIF : le jeu suivant ne s'ouvre que si le jeu précédent est validé à 100% (allDone),
   et non plus simplement "tenté" (.some). */
function gStatus(gid){
  const idx=GO.indexOf(gid);if(idx===0)return allDone(gid)?"done":"open";
  const prevDone=allDone(GO[idx-1]);
  return prevDone?(allDone(gid)?"done":"open"):"locked";
}
/* Niveau suivant ouvert seulement si le précédent est 100% validé */
function lStatus(gid,level){
  const entry=progress[pk(gid,level)];if(entry&&entry.done)return"done";
  const levels=LO[gid];const idx=levels.indexOf(level);
  if(idx===0)return"open";
  const prev=progress[pk(gid,levels[idx-1])];
  return(prev&&prev.done)?"open":"locked";
}
/* CORRECTIF : la Zone d'Aomine ne s'affiche que si TOUS les jeux sont validés à 100%,
   et non plus simplement "joués" (.some). */
function anyPlayed(){return GO.every(gid=>allDone(gid));}

function renderHub(){
  const wrap=document.getElementById("games-wrap");wrap.innerHTML="";
  GO.forEach(gid=>{
    const g=GAMES[gid],st=gStatus(gid);
    const card=document.createElement("div");card.className="game-card"+(st==="locked"?" locked":"");
    card.innerHTML='<div class="gc-icon">'+g.icon+'</div><div class="gc-title">'+g.label+'</div><div class="gc-desc">'+g.desc+'</div><div class="gc-meta"><span class="pill '+(st==="done"?"done":(st==="open"?"open":""))+'">'+
      (st==="locked"?"Verrouillé":st==="done"?"Terminé":"Ouvert")+'</span></div>';
    card.addEventListener("click",()=>{if(st!=="locked")openLevels(gid);});
    wrap.appendChild(card);
  });
  let zb=document.getElementById("zone-inline");
  if(!zb){zb=document.createElement("div");zb.id="zone-inline";document.getElementById("games-wrap").parentElement.appendChild(zb);}
  if(anyPlayed()){
    zb.innerHTML='<div class="zone-card" style="cursor:pointer;" id="zone-inline-btn"><p class="zone-title">✨ Enclos VIP — Daiki Aomine</p><p class="zone-desc">🐣 Tu as fait éclore tous les œufs des deux jeux ! Envoie ton dossier d\'adoption à Aomine Daiki pour tenter le défi final.</p></div>';
    document.getElementById("zone-inline-btn").addEventListener("click",()=>show("screen-zone"));
